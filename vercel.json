{
  "version": 2,
  "builds": [
    {
      "src": "backend/src/server.ts",
      "use": "@vercel/node"
    },
    {
      "src": "web/src/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/favicon.ico",
      "dest": "backend/src/server.ts"
    },
    {
      "src": "/api/v1/(.*)",
      "dest": "backend/src/server.ts"
    },
    {
      "src": "/auth/(.*)",
      "dest": "backend/src/server.ts"
    },
    {
      "src": "/api/(.*)",
      "dest": "web/src/index.ts"
    },
    {
      "src": "/(.*)",
      "dest": "web/src/index.ts"
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false
}
